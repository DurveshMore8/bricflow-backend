{
    "compilerOptions": {
        "target": "ES2020",
        "module": "node16",

        "rootDir": "./",
        "outDir": "./dist",

        "strict": true,

        "esModuleInterop": true,

        "skipLibCheck": true,

        "forceConsistentCasingInFileNames": true,

        "moduleResolution": "node16",

        "resolveJsonModule": true
    },

    "include": ["src", "tests"],

    "exclude": ["node_modules"]
}
